VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Bank Sync (Teller) — optional. The application ID is a public
# identifier (like a Stripe publishable key), safe to ship to the
# browser. Your Teller access tokens are never stored here — they live
# server-side only, handled by supabase/functions/. See README.
VITE_TELLER_APPLICATION_ID=your-teller-application-id
VITE_TELLER_ENVIRONMENT=sandbox
